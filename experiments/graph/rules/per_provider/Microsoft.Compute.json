      "docsRef": "https://learn.microsoft.com/en-us/azure/templates/microsoft.compute/virtualmachines",
      "notes": ""
    },
    {
      "sourceType": "Microsoft.Compute/virtualMachines",
      "propertyPath": "properties.proximityPlacementGroup",
      "valueShape": "object{id:resourceId}",
      "cardinality": "0..1",
      "targetType": "Microsoft.Compute/proximityPlacementGroups",
      "relationshipKind": "connection",
      "label": "in ppg",
      "docsRef": "https://learn.microsoft.com/en-us/azure/templates/microsoft.compute/virtualmachines",
      "notes": ""
    },
    {
      "sourceType": "Microsoft.Compute/virtualMachineScaleSets",
      "propertyPath": "properties.proximityPlacementGroup",
      "valueShape": "object{id:resourceId}",
      "cardinality": "0..1",
      "targetType": "Microsoft.Compute/proximityPlacementGroups",
      "relationshipKind": "connection",
      "label": "in ppg",
      "docsRef": "https://learn.microsoft.com/en-us/azure/templates/microsoft.compute/virtualmachinescalesets",
      "notes": ""
    },
    {
      "sourceType": "Microsoft.Compute/snapshots",
      "propertyPath": "properties.creationData.sourceResourceId",
      "valueShape": "resourceId",
      "cardinality": "0..1",
