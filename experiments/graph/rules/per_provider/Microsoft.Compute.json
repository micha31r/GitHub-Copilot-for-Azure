      "relationshipKind": "connection",
      "label": "snapshot of",
      "docsRef": "https://learn.microsoft.com/en-us/azure/templates/microsoft.compute/snapshots",
      "notes": "sourceResourceId may also reference another snapshot or a managed image; rule keeps the most common case."
