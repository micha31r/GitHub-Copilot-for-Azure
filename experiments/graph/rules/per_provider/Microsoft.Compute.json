      "cardinality": "0..1",
      "targetType": "Microsoft.Compute/virtualMachines",
      "relationshipKind": "connection",
      "label": "managed by",
      "docsRef": "https://learn.microsoft.com/en-us/azure/templates/microsoft.compute/disks",
      "notes": "Disk is attached to a VM. Empty when unattached."
    },
    {
      "sourceType": "Microsoft.Compute/virtualMachines",
      "propertyPath": "properties.storageProfile.osDisk.managedDisk",
