      "cardinality": "0..1",
      "targetType": "Microsoft.Compute/disks",
      "relationshipKind": "connection",
      "label": "uses os disk",
      "docsRef": "https://learn.microsoft.com/en-us/azure/templates/microsoft.compute/virtualmachines",
      "notes": ""
    },
    {
      "sourceType": "Microsoft.Compute/virtualMachines",
      "propertyPath": "properties.storageProfile.dataDisks[].managedDisk",
