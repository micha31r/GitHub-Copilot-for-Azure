{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "./scripts/thinking-log.sh",
        "powershell": "./scripts/thinking-log.ps1",
        "cwd": ".github/hooks",
        "env": { "HOOK_EVENT": "sessionStart" },
        "timeoutSec": 10
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "./scripts/thinking-log.sh",
        "powershell": "./scripts/thinking-log.ps1",
        "cwd": ".github/hooks",
        "env": { "HOOK_EVENT": "sessionEnd" },
        "timeoutSec": 10
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "./scripts/thinking-log.sh",
        "powershell": "./scripts/thinking-log.ps1",
        "cwd": ".github/hooks",
        "env": { "HOOK_EVENT": "userPromptSubmitted" },
        "timeoutSec": 10
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "./scripts/thinking-log.sh",
        "powershell": "./scripts/thinking-log.ps1",
        "cwd": ".github/hooks",
        "env": { "HOOK_EVENT": "preToolUse" },
        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "./scripts/thinking-log.sh",
        "powershell": "./scripts/thinking-log.ps1",
        "cwd": ".github/hooks",
        "env": { "HOOK_EVENT": "postToolUse" },
        "timeoutSec": 10
      }
    ],
    "agentStop": [
      {
        "type": "command",
        "bash": "./scripts/thinking-log.sh",
        "powershell": "./scripts/thinking-log.ps1",
        "cwd": ".github/hooks",
        "env": { "HOOK_EVENT": "agentStop" },
        "timeoutSec": 10
      }
    ],
    "subagentStop": [
      {
        "type": "command",
        "bash": "./scripts/thinking-log.sh",
        "powershell": "./scripts/thinking-log.ps1",
        "cwd": ".github/hooks",
        "env": { "HOOK_EVENT": "subagentStop" },
        "timeoutSec": 10
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "bash": "./scripts/thinking-log.sh",
        "powershell": "./scripts/thinking-log.ps1",
        "cwd": ".github/hooks",
        "env": { "HOOK_EVENT": "errorOccurred" },
        "timeoutSec": 10
      }
    ]
  }
}
